.page {
  background: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 140rpx;
}

.profile-card {
  display: flex;
  padding: 40rpx 30rpx 30rpx;
  background: linear-gradient(135deg, #ffb36a 0%, #f08c2e 100%);
  color: #fff;
}

.avatar {
  width: 180rpx;
  height: 230rpx;
  border-radius: 16rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.35);
  margin-right: 28rpx;
  flex-shrink: 0;
  background: #eee;
}

.profile-right {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.name-row {
  display: flex;
  align-items: center;
  margin-bottom: 14rpx;
}

.name {
  font-size: 42rpx;
  font-weight: 700;
  margin-right: 16rpx;
}

.status-badge {
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.2);
  border: 1rpx solid rgba(255, 255, 255, 0.4);
}

.location-row {
  font-size: 24rpx;
  opacity: 0.95;
  margin-bottom: 12rpx;
}

.stats-row {
  font-size: 26rpx;
  opacity: 0.95;
  margin-bottom: 12rpx;
}

.sep {
  margin: 0 10rpx;
  opacity: 0.6;
}

.rating-row {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.star {
  font-size: 28rpx;
  color: #ffe066;
}

.rating-num {
  font-size: 28rpx;
  font-weight: 700;
}

.rating-label {
  font-size: 22rpx;
  opacity: 0.78;
  margin-left: 4rpx;
}

.verify-bar {
  display: flex;
  flex-wrap: wrap;
  background: #fff;
  padding: 20rpx 30rpx;
  gap: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.verify-item {
  font-size: 22rpx;
  color: #52c41a;
  background: rgba(82, 196, 26, 0.06);
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
}

.section {
  background: #fff;
  margin: 20rpx 0;
  padding: 30rpx;
}

.section-title {
  display: flex;
  align-items: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 24rpx;
}

.title-bar {
  width: 8rpx;
  height: 32rpx;
  background: #f08c2e;
  border-radius: 4rpx;
  margin-right: 14rpx;
}

.info-row {
  display: flex;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f7f7f7;
  font-size: 28rpx;
  line-height: 1.5;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  width: 170rpx;
  color: #999;
  flex-shrink: 0;
}

.info-value {
  flex: 1;
  color: #333;
}

.intro-content,
.experience-content {
  font-size: 28rpx;
  color: #555;
  line-height: 1.8;
  white-space: pre-wrap;
  word-break: break-all;
}

.skills-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.skill-tag {
  font-size: 24rpx;
  color: #f08c2e;
  background: rgba(240, 140, 46, 0.08);
  border: 1rpx solid rgba(240, 140, 46, 0.3);
  padding: 10rpx 24rpx;
  border-radius: 8rpx;
}

.experience-item,
.reason-item {
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f6f6f6;
}

.experience-item:last-child,
.reason-item:last-child {
  border-bottom: none;
}

.experience-period {
  font-size: 24rpx;
  color: #f08c2e;
  margin-bottom: 8rpx;
}

.experience-company {
  font-size: 24rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.reason-item {
  font-size: 26rpx;
  color: #555;
  line-height: 1.7;
}

.cert-gallery {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.cert-item {
  width: calc(33.33% - 14rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.cert-img {
  width: 100%;
  height: 180rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
}

.cert-label {
  font-size: 20rpx;
  color: #999;
  margin-top: 8rpx;
  text-align: center;
}

.bottom-space {
  height: 20rpx;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 110rpx;
  background: #fff;
  display: flex;
  align-items: center;
  padding: 0 30rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
  padding-bottom: env(safe-area-inset-bottom);
  gap: 20rpx;
}

.btn-share {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  color: #333;
  font-size: 28rpx;
  height: 80rpx;
  border-radius: 40rpx;
  padding: 0;
  line-height: 80rpx;
}

.btn-share::after {
  border: none;
}

.btn-book {
  flex: 1.5;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f08c2e;
  color: #fff;
  font-size: 28rpx;
  height: 80rpx;
  border-radius: 40rpx;
  font-weight: 500;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 999;
}

.modal-content {
  position: fixed;
  bottom: -700rpx;
  left: 0;
  right: 0;
  background: #fff;
  border-top-left-radius: 32rpx;
  border-top-right-radius: 32rpx;
  padding: 40rpx 40rpx calc(40rpx + env(safe-area-inset-bottom));
  z-index: 1000;
  transition: bottom 0.3s ease;
}

.modal-show {
  bottom: 0;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
}

.modal-close {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
  padding: 0 10rpx;
}

.modal-desc {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 36rpx;
}

.form-group {
  margin-bottom: 28rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.input {
  background: #f7f8fa;
  height: 88rpx;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
}

.submit-btn {
  background: #f08c2e;
  color: #fff;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 500;
  margin-top: 40rpx;
}

.loading-state {
  height: 100vh;
  display: flex;
  justify-content: center;
  align-items: center;
  color: #999;
  background: #f5f5f5;
  font-size: 28rpx;
}
