<view class="page">
  <view class="loading-state" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <block wx:if="{{!loading && worker}}">
    <view class="profile-card">
      <image
        class="avatar"
        src="{{worker.avatar_url || defaultAvatar}}"
        mode="aspectFill"
        bindtap="previewAvatar"
      ></image>
      <view class="profile-right">
        <view class="name-row">
          <text class="name">{{worker.display_name}}</text>
        </view>
        <view class="location-row" wx:if="{{worker.address}}">
          <text>{{worker.address}}</text>
        </view>
        <view class="stats-row">
          <text>{{worker.age || '--'}}岁</text>
          <text class="sep">|</text>
          <text>{{worker.experience_years || 0}}年经验</text>
          <text class="sep">|</text>
          <text>{{worker.gender === 'female' ? '女' : '男'}}</text>
        </view>
        <view class="rating-row">
          <text class="star">★</text>
          <text class="rating-num">{{worker.rating || '5.0'}}</text>
          <text class="rating-label">综合评分</text>
        </view>
      </view>
    </view>

    <view class="verify-bar">
      <view
        class="verify-item {{item.verified ? 'ok' : ''}}"
        wx:for="{{worker.certBadges}}"
        wx:key="key"
      >
        <text>{{item.label}}</text>
      </view>
    </view>

    <view class="section">
      <view class="section-title">
        <view class="title-bar"></view>
        <text>基本信息</text>
      </view>
      <view class="info-row" wx:if="{{worker.jobTypesText}}">
        <text class="info-label">接单类型</text>
        <text class="info-value">{{worker.jobTypesText}}</text>
      </view>
      <view class="info-row" wx:if="{{worker.zodiac}}">
        <text class="info-label">属相</text>
        <text class="info-value">{{worker.zodiac}}</text>
      </view>
      <view class="info-row" wx:if="{{worker.marital_status}}">
        <text class="info-label">婚姻状态</text>
        <text class="info-value">{{worker.marital_status}}</text>
      </view>
      <view class="info-row" wx:if="{{worker.education}}">
        <text class="info-label">学历</text>
        <text class="info-value">{{worker.education}}</text>
      </view>
      <view class="info-row" wx:if="{{worker.native_place}}">
        <text class="info-label">籍贯</text>
        <text class="info-value">{{worker.native_place}}</text>
      </view>
      <view class="info-row" wx:if="{{worker.address}}">
        <text class="info-label">现居住地</text>
        <text class="info-value">{{worker.address}}</text>
      </view>
      <view class="info-row" wx:if="{{worker.serviceAreasText}}">
        <text class="info-label">服务区域</text>
        <text class="info-value">{{worker.serviceAreasText}}</text>
      </view>
    </view>

    <view class="section" wx:if="{{worker.hasStructuredIntro || worker.introduction}}">
      <view class="section-title">
        <view class="title-bar"></view>
        <text>个人介绍</text>
      </view>
      <view class="intro-block" wx:if="{{worker.hasStructuredIntro}}">
        <view class="intro-row" wx:if="{{worker.family_situation}}">
          <text class="intro-label">家庭情况</text>
          <text class="intro-value">{{worker.family_situation}}</text>
        </view>
        <view class="intro-row" wx:if="{{worker.personality_desc}}">
          <text class="intro-label">性格描述</text>
          <text class="intro-value">{{worker.personality_desc}}</text>
        </view>
        <view class="intro-row" wx:if="{{worker.personality_hobbies}}">
          <text class="intro-label">性格爱好</text>
          <text class="intro-value">{{worker.personality_hobbies}}</text>
        </view>
        <view class="intro-row" wx:if="{{worker.skilled_work}}">
          <text class="intro-label">擅长工作</text>
          <text class="intro-value">{{worker.skilled_work}}</text>
        </view>
      </view>
      <view class="intro-content" wx:elif="{{worker.introduction}}">{{worker.introduction}}</view>
    </view>

    <view class="section" wx:if="{{worker.skillsArray.length > 0}}">
      <view class="section-title">
        <view class="title-bar"></view>
        <text>专业技能</text>
      </view>
      <view class="skills-wrap">
        <view class="skill-tag" wx:for="{{worker.skillsArray}}" wx:key="*this">{{item}}</view>
      </view>
    </view>

    <view class="section" wx:if="{{worker.workExperiences.length > 0}}">
      <view class="section-title">
        <view class="title-bar"></view>
        <text>工作履历</text>
      </view>
      <view class="experience-item" wx:for="{{worker.workExperiences}}" wx:key="id">
        <view class="experience-period">{{item.start_date || '开始时间待补充'}} 至 {{item.end_date || '至今'}}</view>
        <view class="experience-company" wx:if="{{item.company_name}}">{{item.company_name}}</view>
        <view class="experience-content">工作内容：{{item.job_content}}</view>
      </view>
    </view>

    <view class="section" wx:if="{{worker.recommendedReasons.length > 0}}">
      <view class="section-title">
        <view class="title-bar"></view>
        <text>推荐理由</text>
      </view>
      <view class="reason-item" wx:for="{{worker.recommendedReasons}}" wx:key="index">
        <text>{{index + 1}}. {{item}}</text>
      </view>
    </view>

    <view class="section" wx:if="{{worker.lifePhotos.length > 0}}">
      <view class="section-title">
        <view class="title-bar"></view>
        <text>生活工作照片</text>
      </view>
      <view class="cert-gallery">
        <view class="cert-item" wx:for="{{worker.lifePhotos}}" wx:key="*this" bindtap="previewLifePhoto" data-url="{{item}}">
          <image class="cert-img" src="{{item}}" mode="aspectFill"></image>
        </view>
      </view>
    </view>

    <view class="section" wx:if="{{worker.certImages.length > 0}}">
      <view class="section-title">
        <view class="title-bar"></view>
        <text>资质证明</text>
      </view>
      <view class="cert-gallery">
        <view class="cert-item" wx:for="{{worker.certImages}}" wx:key="url" bindtap="previewCert" data-url="{{item.url}}">
          <image class="cert-img" src="{{item.url}}" mode="aspectFill"></image>
          <text class="cert-label">{{item.label}}</text>
        </view>
      </view>
    </view>

    <view class="section guarantee-section">
      <view class="section-title">
        <view class="title-bar"></view>
        <text>服务保障</text>
      </view>
      <view class="guarantee-item" wx:for="{{worker.serviceGuarantees}}" wx:for-index="gIdx" wx:key="*this">
        <text>{{gIdx + 1}}、{{item}}</text>
      </view>
    </view>

    <view class="bottom-space"></view>
  </block>

  <view class="bottom-bar" wx:if="{{!loading && worker && !showModal && !showPrivacyModal}}">
    <button class="btn-share" open-type="share" bindtap="onShareTap">
      <text>分享给好友</text>
    </button>
    <view class="btn-book" bindtap="showBookModal">
      <text>给我留言</text>
    </view>
  </view>

  <block wx:if="{{!loading && worker}}">
    <view class="modal-mask" wx:if="{{showPrivacyModal}}" bindtap="hidePrivacyModal" catchtouchmove="preventMove"></view>
    <view class="privacy-modal {{showPrivacyModal ? 'modal-show' : ''}}" wx:if="{{showPrivacyModal}}">
      <view class="privacy-title">隐私授权提示</view>
      <view class="privacy-content">
        <view class="privacy-desc">在您提交留言前，我们需要收集您的手机号码用于联系确认与服务通知。</view>
        <view class="privacy-agreement">
          <text class="normal-text">请阅读并同意</text>
          <text class="link-text" bindtap="goToPrivacy">《隐私政策》</text>
          <text class="normal-text">和</text>
          <text class="link-text" bindtap="goToAgreement">《用户服务协议》</text>
        </view>
      </view>
      <view class="privacy-btns">
        <view class="btn-cancel" bindtap="hidePrivacyModal">取消</view>
        <view class="btn-agree" bindtap="agreePrivacy">同意</view>
      </view>
    </view>

    <view class="modal-mask" wx:if="{{showModal}}" bindtap="hideBookModal" catchtouchmove="preventMove"></view>
    <view class="modal-content modal-show" wx:if="{{showModal}}" catchtouchmove="preventMove">
      <view class="modal-header">
        <text class="modal-title">预约留言</text>
        <text class="modal-close" bindtap="hideBookModal">×</text>
      </view>
      <scroll-view class="modal-body" scroll-y>
        <view class="modal-desc">留下联系方式，我们会尽快与您联系</view>
        <view class="form-group">
          <text class="label">您的称呼</text>
          <input class="input" placeholder="请输入您的称呼" bindinput="onNameInput" value="{{form.name}}" />
        </view>
        <view class="form-group">
          <text class="label">手机号码</text>
          <input class="input" type="number" maxlength="11" placeholder="请输入手机号" bindinput="onPhoneInput" value="{{form.phone}}" />
        </view>
        <view class="form-group">
          <text class="label">客户需求（选填）</text>
          <textarea class="textarea" placeholder="请描述您的服务需求，如服务类型、时间等" bindinput="onDemandInput" value="{{form.demand}}" maxlength="500" />
        </view>
        <view class="submit-btn" bindtap="submitLead">提交留言</view>
      </scroll-view>
    </view>
  </block>
</view>
