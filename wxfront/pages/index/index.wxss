.container {
  min-height: 100vh;
  background: #f7f8fa;
}

.header {
  padding: 40rpx 30rpx;
  background: linear-gradient(180deg, #ffb36a 0%, #fff3e5 100%);
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #7a4210;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 24rpx;
  color: #a7662c;
}

.filter-panel {
  margin: 0 24rpx 20rpx;
  padding: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.quick-filters {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.quick-item {
  padding: 10rpx 20rpx;
  font-size: 24rpx;
  color: #7f7f7f;
  background: #f4f5f7;
  border-radius: 999rpx;
}

.quick-item.active {
  color: #fff;
  background: #f08c2e;
}

.search-grid {
  display: grid;
  gap: 12rpx;
}

.filter-input,
.picker-input {
  height: 72rpx;
  line-height: 72rpx;
  background: #f7f8fa;
  border-radius: 10rpx;
  padding: 0 18rpx;
  font-size: 24rpx;
  color: #333;
}

.picker-input {
  color: #666;
}

.action-row {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
}

.action-btn {
  flex: 1;
  height: 68rpx;
  line-height: 68rpx;
  text-align: center;
  border-radius: 10rpx;
  font-size: 24rpx;
}

.action-btn.primary {
  background: #f08c2e;
  color: #fff;
}

.action-btn.ghost {
  background: #f1f2f4;
  color: #666;
}

.worker-list {
  padding: 0 24rpx 24rpx;
}

.worker-card {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.03);
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  background: #eee;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.info {
  flex: 1;
  min-width: 0;
}

.name-row,
.status-row,
.desc-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.name-row {
  margin-bottom: 10rpx;
}

.name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.rating {
  font-size: 24rpx;
  color: #f08c2e;
  font-weight: 700;
}

.status-row {
  margin-bottom: 10rpx;
}

.status-tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  color: #b85b00;
  background: #fff4e8;
}

.completed-orders {
  font-size: 22rpx;
  color: #999;
}

.desc-row {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.job-type {
  font-size: 22rpx;
  color: #8c5a2a;
  margin-bottom: 12rpx;
}

.tags-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.tag {
  font-size: 20rpx;
  color: #f08c2e;
  background: rgba(240, 140, 46, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.loading-status {
  text-align: center;
  padding: 24rpx 0;
  font-size: 24rpx;
  color: #999;
}

.empty-state {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 400rpx;
  font-size: 28rpx;
  color: #999;
}
